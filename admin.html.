<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Administracyjny</title>
    
    <style>
        /* Domyślnie ukrywamy cały panel admina */
        body { 
            margin: 0; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #f4f6f9;
            visibility: hidden; 
        }
        
        /* Styl dla nakładki logowania - widocznej na starcie */
        .login-overlay {
            visibility: visible;
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #1e1e2f; display: flex; justify-content: center;
            align-items: center; z-index: 999999;
        }
        .login-box {
            background: white; padding: 40px; border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.3); text-align: center; width: 340px;
        }
        .login-box h2 { margin-top: 0; margin-bottom: 25px; color: #333; font-size: 24px; }
        .login-box input {
            width: 100%; padding: 12px; margin-bottom: 20px;
            border: 2px solid #e0e0e0; border-radius: 6px; box-sizing: border-box; 
            font-size: 16px; transition: border-color 0.3s;
        }
        .login-box input:focus { border-color: #4e73df; outline: none; }
        .login-box button {
            width: 100%; padding: 12px; background: #4e73df; color: white;
            border: none; border-radius: 6px; cursor: pointer; font-size: 16px; font-weight: bold;
            transition: background 0.3s;
        }
        .login-box button:hover { background: #2e59d9; }
        .error-msg { color: #e74a3b; font-size: 14px; margin-top: 15px; display: none; font-weight: bold; }
    </style>

    <style>
        /* Główne kontenery panelu */
        .admin-container { display: flex; min-height: 100vh; }
        
        /* Menu boczne */
        .sidebar { width: 260px; background: #222e3c; color: #fff; padding: 20px; }
        .sidebar h3 { margin-top: 0; padding-bottom: 20px; border-bottom: 1px solid #2b3947; color: #fff; }
        .sidebar ul { list-style: none; padding: 0; margin: 20px 0; }
        .sidebar ul li { padding: 12px 15px; border-radius: 4px; margin-bottom: 5px; cursor: pointer; transition: 0.2s; }
        .sidebar ul li:hover, .sidebar ul li.active { background: #303e4e; color: #4e73df; font-weight: bold; }
        
        /* Główna zawartość */
        .main-content { flex: 1; padding: 30px; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .header h1 { margin: 0; color: #333; }
        
        /* Karty ze statystykami */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.05); border-left: 5px solid #4e73df; }
        .stat-card.green { border-left-color: #1cc88a; }
        .stat-card.orange { border-left-color: #f6c23e; }
        .stat-card title { font-size: 12px; text-transform: uppercase; color: #858796; font-weight: bold; display: block; margin-bottom: 5px; }
        .stat-card .number { font-size: 24px; font-weight: bold; color: #5a5c69; }
        
        /* Tabela danych */
        .data-section { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.05); }
        .data-section h2 { margin-top: 0; margin-bottom: 20px; color: #333; font-size: 18px; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 12px 15px; border-bottom: 1px solid #e3e6f0; }
        th { background-color: #f8f9fc; color: #4e73df; font-weight: bold; }
        tr:hover { background-color: #f8f9fc; }
        
        /* Przyciski akcji */
        .btn-action { padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; margin-right: 5px; }
        .btn-edit { background: #f6c23e; color: white; }
        .btn-delete { background: #e74a3b; color: white; }
        .btn-logout { background: #858796; color: white; padding: 8px 15px; border: none; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>

    <div id="loginOverlay" class="login-overlay">
        <div class="login-box">
            <h2>Panel Administracyjny</h2>
            <input type="password" id="passwordInput" placeholder="Wprowadź hasło..." onkeydown="if(event.key === 'Enter') checkPassword()">
            <button onclick="checkPassword()">Zaloguj się</button>
            <div id="errorMsg" class="error-msg">Błędne hasło! Spróbuj ponownie.</div>
        </div>
    </div>

    <div class="admin-container">
        <aside class="sidebar">
            <h3>MobiWash Admin</h3>
            <ul>
                <li class="active">Pulpit główny</li>
                <li>Zlecenia / Rezerwacje</li>
                <li>Klienci</li>
                <li>Ustawienia strony</li>
            </ul>
        </aside>

        <main class="main-content">
            <header class="header">
                <h1>Witaj w panelu zarządzania</h1>
                <button class="btn-logout" onclick="logout()">Wyloguj</button>
            </header>

            <section class="stats-grid">
                <div class="stat-card">
                    <title>Nowe zapytania</title>
                    <div class="number">12</div>
                </div>
                <div class="stat-card green">
                    <title>Zrealizowane dziś</title>
                    <div class="number">4</div>
                </div>
                <div class="stat-card orange">
                    <title>Oczekujące opinie</title>
                    <div class="number">6</div>
                </div>
            </section>

            <section class="data-section">
                <h2>Ostatnie wiadomości z formularza</h2>
                <table>
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Klient</th>
                            <th>Usługa</th>
                            <th>Status</th>
                            <th>Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>22.06.2026</td>
                            <td>Jan Kowalski</td>
                            <td>Czyszczenie narożnika</td>
                            <td><span style="color: #1cc88a; font-weight: bold;">Nowe</span></td>
                            <td>
                                <button class="btn-action btn-edit">Podgląd</button>
                                <button class="btn-action btn-delete">Usuń</button>
                            </td>
                        </tr>
                        <tr>
                            <td>21.06.2026</td>
                            <td>Anna Nowak</td>
                            <td>Pranie materaca</td>
                            <td><span style="color: #858796;">W trakcie</span></td>
                            <td>
                                <button class="btn-action btn-edit">Podgląd</button>
                                <button class="btn-action btn-delete">Usuń</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </section>
        </main>
    </div>

    <script>
        function checkPassword() {
            const input = document.getElementById('passwordInput').value;
            const error = document.getElementById('errorMsg');
            
            // Definicja Twojego hasła
            if (input === 'DzieciecaMoc') {
                // Jeśli hasło poprawne: usuwamy okno logowania i odsłaniamy panel
                document.getElementById('loginOverlay').remove();
                document.body.style.visibility = 'visible';
            } else {
                // Jeśli błędne: czyścimy pole i pokazujemy komunikat błędu
                error.style.display = 'block';
                document.getElementById('passwordInput').value = '';
            }
        }

        function logout() {
            // Szybkie przeładowanie strony powoduje ponowne zablokowanie panelem hasła
            window.location.reload();
        }
    </script>

</body>
</html>
